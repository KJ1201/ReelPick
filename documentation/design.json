  "screen_templates": {
    "feed_screen": {
      "layers_from_bottom_to_top": [
        "1. video/image media (position: absolute, full bleed, z-index: 0)",
        "2. bottom vignette gradient (z-index: 1, pointer-events: none)",
        "3. top vignette gradient (z-index: 1, pointer-events: none)",
        "4. product_tags floating over content (z-index: 2)",
        "5. info_overlay bottom-left: seller_avatar_row + product title + price (z-index: 3)",
        "6. reel_action_sidebar bottom-right: like/save/share (z-index: 3)",
        "7. category_filter_bar + top_bar (z-index: 10, position: absolute top-0)",
        "8. navigation_bar (z-index: 200, position: fixed, floating pill)"
      ]
    },
    "product_drawer_state": {
      "description": "When product tag is tapped, feed continues playing underneath",
      "layers": [
        "1–7. (same feed layers, still active, video still playing)",
        "8. scrim overlay: rgba(0,0,0,0.40) animated in (z-index: 50)",
        "9. product_drawer slides up from bottom (z-index: 100)"
      ]
    },
    "try_on_screen": {
      "layers": [
        "1. background_base full screen (z-index: 300)",
        "2. top bar with back button + title",
        "3. main area: photo_upload_zone OR result image",
        "4. confidence_warning (conditional, z-index: 1 within module)",
        "5. before_after_toggle (shown after result loads)",
        "6. bottom action row: try another / add to cart"
      ]
    }
  },

